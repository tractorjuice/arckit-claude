{
  "description": "ArcKit hooks: session init, version check, session learner (Stop + StopFailure), project context injection (UserPromptSubmit + PostCompact rehydrate), filename enforcement, MCP tool auto-allow, security protection (file protection, secret detection, secret file scanning), provenance stamping on artefact writes (PostToolUse Write|Edit), and telemetry recording (PostToolUse for hook duration_ms + govreposcrape MCP calls; TaskCreated for agent spawns). All entries use the `args: string[]` exec form (Claude Code v2.1.139+) to avoid shell-string parsing. PostToolUse entries set `continueOnBlock: true` (v2.1.139+) so a stamping / telemetry / manifest hook can never derail the user's turn — they are observational and must fail soft.",
  "hooks": {
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/session-learner.mjs"],
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/session-learner.mjs"],
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/arckit-session.mjs"],
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/version-check.mjs"],
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/v5-migration-banner.mjs"],
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/notify-stale-artifacts.mjs"],
            "timeout": 8
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/arckit-context.mjs"],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/secret-detection.mjs"],
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "/arckit:pages",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/sync-guides.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "/arckit:health",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs"],
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "/arckit:traceability",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs"],
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "/arckit:analyze",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs"],
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "/arckit:search",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "/arckit:impact",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs"],
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "/arckit:navigator",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "/arckit:graph-report",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs"],
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/allow-plugin-internals.mjs"],
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/inject-agent-context.mjs"],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(/projects/**)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/validate-arc-filename.mjs"],
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Write(/projects/**/vendors/scores.json)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/score-validator.mjs"],
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Write(/projects/**/wardley-maps/**)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/validate-wardley-math.mjs"],
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/file-protection.mjs"],
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/secret-file-scanner.mjs"],
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(/projects/**)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/update-manifest.mjs"],
            "timeout": 5,
            "continueOnBlock": true
          },
          {
            "type": "command",
            "if": "Write(/projects/**)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/provenance-stamp.mjs"],
            "timeout": 5,
            "continueOnBlock": true
          },
          {
            "type": "command",
            "if": "Write(/projects/**/wardley-maps/**)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/tidy-wardley-labels.mjs"],
            "timeout": 10,
            "continueOnBlock": true
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(/projects/**)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/provenance-stamp.mjs"],
            "timeout": 5,
            "continueOnBlock": true
          },
          {
            "type": "command",
            "if": "Edit(/projects/**/wardley-maps/**)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/tidy-wardley-labels.mjs"],
            "timeout": 10,
            "continueOnBlock": true
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/telemetry.mjs"],
            "timeout": 3,
            "continueOnBlock": true
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/telemetry.mjs"],
            "timeout": 3
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/allow-mcp-tools.mjs"],
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/postcompact-rehydrate.mjs"],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
